# Kommo CRM REST API Credentials
KOMMO_SUBDOMAIN=spb
KOMMO_ACCESS_TOKEN=your_long_lived_oauth2_token_here
KOMMO_DRY_RUN=True

# Google Drive Stocklist Polling Credentials
GOOGLE_DRIVE_FOLDER_ID=your_gdrive_folder_id_here
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# E-Agent Portal Credentials (real values go in .env only - never commit them)
E_AGENT_USERNAME=your_eagent_username_here
E_AGENT_PASSWORD=your_eagent_password_here

# Playwright Scraper Settings
SCRAPER_HEADLESS=True
SCRAPER_RATE_LIMIT_S=1.5
SCRAPER_NAV_TIMEOUT_MS=30000

# Server Settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
